{
  "name": "100-seo-tools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "build:analyze": "ANALYZE=true next build",
    "generate:tools": "node scripts/generateTools.js",
    "validate": "node scripts/validate.js",
    "audit:contrast": "node scripts/contrastAudit.js",
    "lint:links": "node scripts/checkExternalLinks.js",
    "lint:canon": "node scripts/lintCanonical.js",
    "lint:anchors": "node scripts/lintAnchors.js",
    "lint:whitespace": "node scripts/whitespaceAudit.js",
    "fix:whitespace": "node scripts/whitespaceAudit.js --fix",
    "crawl:final": "node scripts/headlessCrawler.js"
  },
  "browserslist": {
    "production": [
      "Chrome >= 90",
      "Firefox >= 88",
      "Safari >= 14",
      "Edge >= 90"
