```javascript
// URL Validation
function validateURL(url) {
    const urlPattern = /^(https?:\/\/)?([\da-z\.-]+)\.([a-z\.]{2,6})([\/\w \.-]*)*\/?$/i;
    return urlPattern.test(url);
}

// Domain Validation
function validateDomain(domain) {
    const domainPattern = /^(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\.)+[a-z0-9][a-z0-9-]{0,61}[a-z0-9]$/i;
    return domainPattern.test(domain);
}

// Escape Special Characters for Regex
function escapeRegex(str) {
    return str.replace(/([.*+?^${}()|[\]\\])/g, '\\$1');
}

// Extract Path from URL
function extractPath(url) {
    try {
        const urlObj = new URL(url.startsWith('http') ? url : 'https://example.com' + url);
        return urlObj.pathname + urlObj.search + urlObj.hash;
    } catch {
        return url.startsWith('/') ? url : '/' + url;
    }
}

// Circular Redirect Detection
function detectCircularRedirects(redirects) {
    const graph = new Map();
    redirects.forEach(({from, to}) => {
        if (!graph.has(from)) graph.set(from, []);
        graph.get(from).push(to);
    });
    
    function hasCycle(node, visited, recStack) {
        if (recStack.has(node)) return true;
        if (visited.has(node)) return false;
        
        visited.add(node);
        recStack.add(node);
        
        const neighbors = graph.get(node) || [];
        for (const neighbor of neighbors) {
            if (hasCycle(neighbor, visited, recStack)) return true;
        }
        
        recStack.delete(node);
        return false;
    }
    
    const visited = new Set();
    for (const node of graph.keys()) {
        if (hasCycle(node, visited, new Set())) {
            return true;
        }
    }
    return false;
}

// Generate Apache .htaccess Code
function generateApacheCode(redirects, options) {
    let code = '# 301 Redirect Rules - Generated by 100 SEO Tools\n';
    code += '# ' + new Date().toLocaleString() + '\n\n';
    code += 'RewriteEngine On\n';
    code += 'RewriteBase /\n\n';
    
    if (options.addComments) {
        code += '# Page-to-Page Redirects\n';
    }
    
    redirects.forEach((redirect, index) => {
        const oldPath = extractPath(redirect.from);
        const newUrl = redirect.to;
        const flags = [];
        
        // Add redirect type
        flags.push(`R=${options.redirectType || 301}`);
        flags.push('L'); // Last rule
        
        if (!options.caseSensitive) flags.push('NC'); // No Case
        flags.push('NE'); // No Escape
        
        const escapedPath = escapeRegex(oldPath).replace(/^\//, '');
        
        if (options.exactMatch) {
            code += `RewriteRule ^${escapedPath}$ ${newUrl} [${flags.join(',')}]\n`;
        } else {
            code += `RewriteRule ^${escapedPath}(/.*)?$ ${newUrl}$1 [${flags.join(',')}]\n`;
        }
    });
    
    return code;
}

// Generate Nginx Configuration
function generateNginxCode(redirects, options) {
    let code = '# 301 Redirect Rules - Generated by 100 SEO Tools\n';
    code += '# ' + new Date().toLocaleString() + '\n\n';
    
    redirects.forEach(redirect => {
        const oldPath = extractPath(redirect.from);
        const newUrl = redirect.to;
        
        if (options.exactMatch) {
            code += `location = ${oldPath} {\n`;
            code += `    return ${options.redirectType || 301} ${newUrl};\n`;
            code += `}\n\n`;
        } else {
            code += `rewrite ^${oldPath}$ ${newUrl} permanent;\n`;
        }
    });
    
    return code;
}

// Generate PHP Code
function generatePHPCode(redirects, options) {
    let code = '<?php\n';
    code += '// 301 Redirect - Generated by 100 SEO Tools\n';
    code += '// ' + new Date().toLocaleString() + '\n\n';
    
    if (redirects.length === 1) {
        code += `header("HTTP/1.1 ${options.redirectType || 301} Moved Permanently");\n`;
        code += `header("Location: ${redirects[0].to}");\n`;
        code += 'header("Connection: close");\n';
        code += 'exit();\n';
    } else {
        code += '$request_uri = $_SERVER[\'REQUEST_URI\'];\n\n';
        code += '$redirects = [\n';
        redirects.forEach(r => {
            code += `    '${extractPath(r.from)}' => '${r.to}',\n`;
        });
        code += '];\n\n';
        code += 'if (isset($redirects[$request_uri])) {\n';
        code += `    header("HTTP/1.1 ${options.redirectType || 301} Moved Permanently");\n`;
        code += '    header("Location: " . $redirects[$request_uri]);\n';
        code += '    header("Connection: close");\n';
        code += '    exit();\n';
        code += '}\n';
    }
    code += '?>';
    
    return code;
}

// Parse CSV/Bulk Input
function parseBulkInput(input) {
    const redirects = [];
    const lines = input.trim().split('\n');
    
    lines.forEach((line, index) => {
        const parts = line.split(',').map(s => s.trim());
        if (parts.length >= 2 && parts[0] && parts[1]) {
            redirects.push({
                from: parts[0],
                to: parts[1],
                isValid: validateURL(parts[0]) && validateURL(parts[1])
            });
        }
    });
    
    return redirects;
}

// Export to ZIP
async function exportAllFormats(redirects, options) {
    const zip = new JSZip();
    
    zip.file('.htaccess', generateApacheCode(redirects, options));
    zip.file('nginx.conf', generateNginxCode(redirects, options));
    zip.file('redirect.php', generatePHPCode(redirects, options));
    zip.file('redirect.html', generateHTMLCode(redirects, options));
    zip.file('redirect.js', generateJavaScriptCode(redirects, options));
    
    const content = await zip.generateAsync({type: 'blob'});
    const link = document.createElement('a');
    link.href = URL.createObjectURL(content);
    link.download = '301-redirects-' + Date.now() + '.zip';
    link.click();
}

// Copy to Clipboard with Fallback
function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(text);
    } else {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        try {
            document.execCommand('copy');
            document.body.removeChild(textarea);
            return Promise.resolve();
        } catch (err) {
            document.body.removeChild(textarea);
            return Promise.reject(err);
        }
    }
}
